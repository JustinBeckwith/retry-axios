{
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "sourceMap": true,
    "target": "ES2022",
    "rootDir": ".",
    "outDir": "build",
    "moduleResolution": "nodenext",
    "module": "node20",
    "esModuleInterop": true
  },
  "include": [
    "src/*.ts"
  ]
}
